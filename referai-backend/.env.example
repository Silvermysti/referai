# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# --- AI (DeepSeek — job parsing + resume extraction) ---
# https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- GitHub (employee profile search via GitHub API) ---
GITHUB_PAT=your_github_pat_here

# --- Google Custom Search (LinkedIn profile discovery — optional) ---
# Free tier: 100 queries/day
# 1. Create a CSE at https://programmablesearchengine.google.com/ (search the whole web)
# 2. Get an API key at https://console.cloud.google.com/apis/credentials
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

# --- Ollama (optional — local LLM for career coaching tips) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
